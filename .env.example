# PVE B2 Age Backup Configuration
# Copy to /etc/pve-b2-age-backup/config.env and customize
# Documentation: https://github.com/LukasStrickler/proxmox-b2-offsite-backup/docs/guides/configuration.md
# Quick Start: https://github.com/LukasStrickler/proxmox-b2-offsite-backup/docs/guides/quickstart.md

# ============================================================================
# REQUIRED SETTINGS - MUST BE CONFIGURED
# ============================================================================

# Rclone remote name and bucket for Backblaze B2
# Format: "REMOTE_NAME:BUCKET_NAME"
# Example: "b2:PROXMOX_BACKUPS"
# Setup guide: https://rclone.org/b2/#configuration
# B2 docs: https://www.backblaze.com/docs/cloud-storage-about-backblaze-b2-cloud-storage
RCLONE_REMOTE="b2:YOUR_BUCKET_NAME"

# Local staging directory for vzdump files
# Must have enough space for largest VM + 10% buffer
# Proxmox storage guide: https://pve.proxmox.com/wiki/Storage
DUMPDIR="/backup/vzdump"

# Age encryption recipients file (public keys only)
# One key per line, supports comments with #
# Generate: age-keygen -o age.key
# Extract: grep -oE 'age1[0-9a-z]+' age.key > recipients.txt
# Docs: https://github.com/FiloSottile/age#recipient-files
AGE_RECIPIENTS="/etc/pve-b2-age-backup/recipients.txt"

# Age identity file (private key)
# ONLY needed for restore/verify operations
# Keep SECURE and preferably OFFLINE
AGE_IDENTITY="/etc/pve-b2-age-backup/age.key"

# ============================================================================
# OPTIONAL SETTINGS - Sensible defaults provided
# ============================================================================

# Remote path prefix (subdirectory in bucket)
# Result: b2:BUCKET/{REMOTE_PREFIX}/{HOST}/daily/
REMOTE_PREFIX="proxmox"

# Hostname override (defaults to $(hostname -s))
# Useful for multi-node clusters or custom naming
# HOST="pve-node-01"

# Allow multiple backup files in DUMPDIR at once (default: false)
# Only set true if staging is large enough for multiple concurrent backups.
# When false, the hook fails backup-start if another backup file is present
# (enforces one backup at a time so e.g. 100GB staging works for 8x80GB VMs).
# ALLOW_CONCURRENT_STAGING=true

# ============================================================================
# RETENTION POLICY
# ============================================================================

# Number of daily backups to keep
# Oldest backups are deleted first
KEEP_DAILY=7

# Number of monthly backups to keep
# Monthly copies created on day 01
KEEP_MONTHLY=1

# Number of log files to keep
KEEP_LOGS=30

# Enable automatic monthly copies on day 01
# Creates server-side copy from daily to monthly
ENABLE_MONTHLY=true

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Rclone streaming upload cutoff (controls memory usage)
# Higher = more RAM, fewer API calls
# Lower = less RAM, more API calls
# Format: number + suffix (K, M, G)
# Docs: https://rclone.org/commands/rclone_rcat/#options
RCAT_CUTOFF="8M"

# Number of upload retry attempts
# Total wait time = sum of exponential backoff
UPLOAD_ATTEMPTS=6

# Base delay in seconds for exponential backoff
# Delay = BASE_BACKOFF * (2 ^ (attempt - 1))
# Attempt 1: 20s, Attempt 2: 40s, Attempt 3: 80s, etc.
BASE_BACKOFF=20

# ============================================================================
# VERIFICATION SETTINGS
# ============================================================================

# Compute SHA256 hash during restore operations
# true = verify integrity (slower for large files)
# false = skip verification (faster)
VERIFY_HASH=true

# ============================================================================
# WORK DIRECTORIES
# ============================================================================

# Where to download backups for restore operations
# Must have space for largest backup
# Default Proxmox dump directory
RESTORE_WORKDIR="/var/lib/vz/dump"

# Where to download backups for verification
VERIFY_WORKDIR="/var/tmp"

# Temporary directory for host config backups
WORKDIR="/var/tmp"

# ============================================================================
# LOGGING
# ============================================================================

# Main log file location
LOG="/var/log/pve-b2-age.log"
